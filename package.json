    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
